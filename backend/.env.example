# MiniMax AI configuration (OpenAI-compatible endpoint)
# Get an API key at https://platform.minimaxi.com
# Copy this file to backend/.env and fill in your key.

MINIMAX_API_KEY=your_minimax_api_key_here

# Optional overrides (defaults shown):
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# MINIMAX_MODEL=MiniMax-M2.7
# MAX_TRANSCRIPT_CHARS=60000

# Bilibili: optional cookies for official CC subtitles (otherwise SenseVoice ASR is used)
# YTDLP_COOKIE_FILE=C:/path/to/bilibili_cookies.txt
# YTDLP_COOKIES_FROM_BROWSER=chrome

# Speech recognition fallback (SenseVoice via sherpa-onnx, no login required)
# First run downloads ~200MB model to backend/models/sensevoice/
# ASR_ENABLED=true
# SENSEVOICE_USE_INT8=true
# ASR_THREADS=2
# ASR_MAX_DURATION_SECONDS=1800
# ASR_MODEL_DIR=C:/path/to/custom/model/cache

# Site login (required when AUTH_ENABLED=true)
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=your_strong_password_here
# Generate bcrypt hash: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your_password'))"
# AUTH_PASSWORD=$2b$12$...
AUTH_SESSION_SECRET=change-me-to-a-random-32-char-string
# AUTH_SESSION_MAX_AGE=86400
# AUTH_LOGIN_MAX_ATTEMPTS=5
# AUTH_LOGIN_LOCKOUT_SECONDS=300
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174
